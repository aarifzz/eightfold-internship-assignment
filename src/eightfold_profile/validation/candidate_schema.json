{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eightfold.example/schemas/candidate-profile.json",
  "title": "Canonical Candidate Profile",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "full_name": { "type": "string", "minLength": 1 },
    "emails": {
      "type": "array",
      "items": { "type": "string", "format": "email" }
    },
    "phones": {
      "type": "array",
      "items": { "type": "string", "pattern": "^\\+[1-9]\\d{1,14}$" }
    },
    "location": { "$ref": "#/$defs/location_object" },
    "links": { "$ref": "#/$defs/links_object" },
    "headline": { "type": ["string", "null"] },
    "years_experience": { "type": ["number", "null"], "minimum": 0 },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skill_item" }
    },
    "experience": {
      "type": "array",
      "items": { "$ref": "#/$defs/experience_item" }
    },
    "education": {
      "type": "array",
      "items": { "$ref": "#/$defs/education_item" }
    },
    "provenance": {
      "type": "array",
      "items": { "$ref": "#/$defs/provenance_record" }
    },
    "overall_confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  },
  "$defs": {
    "provenance_record": {
      "type": "object",
      "required": ["field", "source", "method"],
      "properties": {
        "field": { "type": "string" },
        "source": { "type": "string", "enum": ["recruiter_csv", "resume_pdf"] },
        "method": { "type": "string" }
      },
      "additionalProperties": false
    },
    "location_object": {
      "type": "object",
      "required": ["country"],
      "properties": {
        "city": { "type": "string" },
        "region": { "type": "string" },
        "country": { "type": "string", "pattern": "^[A-Z]{2}$" }
      },
      "additionalProperties": false
    },
    "links_object": {
      "type": "object",
      "required": ["other"],
      "properties": {
        "linkedin": { "type": ["string", "null"], "format": "uri" },
        "github": { "type": ["string", "null"], "format": "uri" },
        "portfolio": { "type": ["string", "null"], "format": "uri" },
        "other": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        }
      },
      "additionalProperties": false
    },
    "skill_item": {
      "type": "object",
      "required": ["name", "confidence", "sources"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "sources": {
          "type": "array",
          "items": { "type": "string", "enum": ["recruiter_csv", "resume_pdf"] }
        }
      },
      "additionalProperties": false
    },
    "experience_item": {
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "title": { "type": "string" },
        "start": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
        "end": { "type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}$" },
        "summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "education_item": {
      "type": "object",
      "properties": {
        "institution": { "type": "string" },
        "degree": { "type": "string" },
        "field": { "type": "string" },
        "end_year": { "type": "integer", "minimum": 1900, "maximum": 2100 }
      },
      "additionalProperties": false
    }
  }
}
